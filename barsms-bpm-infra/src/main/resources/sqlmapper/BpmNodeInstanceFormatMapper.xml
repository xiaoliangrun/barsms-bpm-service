<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cpic.barsms.bpm.infra.mapper.BpmNodeInstanceFormatMapper">

    <resultMap id="BpmNodeInstanceFormatResultMap" type="com.cpic.barsms.bpm.infra.model.entity.BpmNodeInstanceFormat">
        <id column="id" property="id"/>
        <result column="version_name" property="versionName"/>
        <result column="node_code" property="nodeCode"/>
        <result column="title" property="title"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="org_level" property="orgLevel"/>
        <result column="dept_name" property="deptName"/>
        <result column="office_name" property="officeName"/>
        <result column="delivery_info" property="deliveryInfo"/>
        <result column="sql5_text" property="sql5Text"/>
        <result column="scene_name" property="sceneName"/>
        <result column="node_type_category" property="nodeTypeCategory"/>
        <result column="node_type_name" property="nodeTypeName"/>
        <result column="due_date" property="dueDate"/>
        <result column="planned_start" property="plannedStart"/>
        <result column="planned_end" property="plannedEnd"/>
        <result column="data_org_level" property="dataOrgLevel"/>
        <result column="channel" property="channel"/>
        <result column="t_day" property="tDay"/>
        <result column="created_by" property="createBy"/>
        <result column="created_at" property="createTime"/>
        <result column="updated_by" property="updateBy"/>
        <result column="updated_at" property="updateTime"/>
        <result column="delete_flag" property="deleteFlag"/>
    </resultMap>

    <select id="selectTemplates" resultMap="BpmNodeInstanceFormatResultMap">
        SELECT id, version_name, node_code, title, status, description,
               org_level, dept_name, office_name,
               delivery_info, sql5_text, scene_name,
               node_type_category, node_type_name,
               due_date, planned_start, planned_end,
               data_org_level, channel,
               created_by, created_at,
               updated_by, updated_at, delete_flag, t_day
        FROM bpm_node_instance_format
        WHERE 1 = 1
          <if test="tDay != null">
              AND t_day = #{tDay}
          </if>
          <if test="versionName != null and versionName != ''">
              AND version_name = #{versionName}
          </if>
          <if test="procDateType != null">
              AND sql5_text = #{procDateType.code}
          </if>
          <if test="orgLevelLike != null and orgLevelLike != ''">
              AND org_level LIKE #{orgLevelLike}
          </if>
          <if test="nodeCodePrefix != null and nodeCodePrefix != ''">
              AND node_code LIKE CONCAT(#{nodeCodePrefix}, '%')
          </if>
          AND delete_flag = '0'
    </select>

</mapper>
